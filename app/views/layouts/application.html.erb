<!DOCTYPE html>
<html>
  <head>
    <title>AnimeSearch</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="algolia-app-id"     content="<%= ENV['ALGOLIA_APP_ID'] %>">
    <meta name="algolia-search-key" content="<%= ENV['ALGOLIA_SEARCH_ONLY_KEY'] %>">
    <meta name="algolia-index"      content="animes_<%= Rails.env %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script src="https://cdn.jsdelivr.net/npm/algoliasearch@4/dist/algoliasearch-lite.umd.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/instantsearch.js@4/dist/instantsearch.production.min.js"></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="nav">
      <%= link_to root_path, class: "nav-brand" do %>
        <span class="nav-dot"></span>
        AnimeSearch
      <% end %>
      <div class="nav-links">
        <%= link_to "Animes",  animes_path,  class: ("active" if controller_name == "animes") %>
        <%= link_to "Genres",  genres_path,  class: ("active" if controller_name == "genres") %>
        <%= link_to "Studios", studios_path, class: ("active" if controller_name == "studios") %>
      </div>
    </nav>
    <%= yield %>
  </body>
</html>
